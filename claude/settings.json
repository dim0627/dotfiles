      "Bash(pnpm install)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm build *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm test *)",
      "Bash(pnpm test)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm biome *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm tsc *)",
      "Bash(npx tsc *)",
