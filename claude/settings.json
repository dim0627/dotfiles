      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(sips *)",
      "Bash(convert *)",
      "Bash(afplay *)",
      "Bash(cd *)",
      "WebSearch",
      "mcp__linear__get_issue",
      "mcp__linear__list_comments",
      "mcp__linear__list_issues",
      "mcp__claude_ai_Linear__get_issue",
      "mcp__claude_ai_Linear__list_comments",
      "mcp__claude_ai_Linear__list_issues",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__render__get_metrics",
      "mcp__sentry__get_sentry_resource"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -uw -t \"$TMUX_PANE\" @claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          },
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude 1 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Purr.aiff"
          },
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude 1 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "agentoast hook claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentoast hook claude"
          },
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude 1 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -uw -t \"$TMUX_PANE\" @claude 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/tsujidaisuke/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "voltagent-qa-sec@voltagent-subagents": false,
    "voltagent-biz@voltagent-subagents": false,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "voltagent-subagents": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      }
    }
  },
  "skipWorkflowUsageWarning": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
